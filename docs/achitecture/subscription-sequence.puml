@startuml Subscription Module - Sequence Diagram
!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequenceArrowColor #555555
skinparam sequenceLifeLineBorderColor #444444
skinparam sequenceParticipantBorderColor #444444
skinparam sequenceBoxBorderColor #666666
skinparam defaultFontSize 11
skinparam noteBorderColor #CC0000
skinparam noteBackgroundColor #FF4444
skinparam noteFontColor #FFFFFF

title Subscription Module - Sequence Diagram

' ============================================================
' PARTICIPANTS
' ============================================================

actor "User" as user
actor "Backend\n(BACKEND_ADMIN)" as backend
actor "Operator\n(OPERATOR)" as operator
participant "ReferralGateway" as rg #E1BEE7
box "Modules" #E8F5E9
  participant "SubscriptionModule" as sub #C8E6C9
  participant "MainStorageModule" as ms #C8E6C9
  participant "KYCModule" as kyc #C8E6C9
  participant "ReferralRewardsModule" as rr #C8E6C9
  participant "RevenueModule" as rev #C8E6C9
end box
participant "USDC" as usdc #EEEEEE

note over sub #FF4444
  <color:#FFFFFF><b>START HERE</b></color>
end note

' ============================================================
' FLOW 1: USER PAYS SUBSCRIPTION (direct)
' ============================================================

== Flow 1: User Pays Subscription ==

user -> sub ++ : pay subscription\n(plan price, optional parent)
  sub -> rr ++ : calculate referral rewards\n(contribution, coupon, parent, fee)

    rr -> rr : compute referral reserve\n(2% of contribution)

    alt parent provided
      rr -> kyc : check parent is KYC verified
      kyc --> rr : KYC status

      alt parent is KYC verified
        rr -> rr : compute child discount
        rr -> rr : Queue rewards for each parent layer
        note right of rr : rewards are stored as\npending, paid out later\nin "reward parents" call
        rr --> sub : fee (unchanged), discount, reserve amount
      else parent not KYC verified
        rr --> sub : fee (reduced by reserve), no discount, reserve amount
      end

    else no parent
      rr -> rr : deduct reserve from fee
      rr --> sub : fee (reduced by reserve), no discount, reserve amount
    end
  deactivate rr

  group Token transfers
    sub -> usdc : pull contribution from user
    sub -> usdc : send fee to fee claimer
    alt has referral reserve
      sub -> usdc : send referral reserve\nto ReferralRewards
    end
  end

  alt new member
    sub -> ms : create association member\n(state: Inactive, awaiting KYC)
  else rejoin (was refunded)
    sub -> ms : update association member\n(keep same ID, reset state)
  end

  alt has parent
    sub -> ms : add child to parent's referral tree
  end
sub --> user : subscription paid
deactivate sub

' ============================================================
' FLOW 2: BACKEND PAYS ON BEHALF
' ============================================================

== Flow 2: Backend Pays on Behalf ==

backend -> sub ++ : pay subscription on behalf\n(user, parent, price, coupon, start time)

  note right of sub : same internal flow\nas user direct payment\n(see Flow 1)

  sub -> ms : create or update member
sub --> backend : subscription paid
deactivate sub

' ============================================================
' FLOW 3: JOIN FROM REFERRAL GATEWAY
' ============================================================

== Flow 3: Join from Referral Gateway ==

user -> rg ++ : join via referral
  rg -> sub ++ : join from referral gateway\n(user, parent, contribution, duration)
    note right of sub : processes subscription\nwith gateway parameters
  sub --> rg : done
  deactivate sub
rg --> user : joined
deactivate rg

' ============================================================
' FLOW 4: TRANSFER SUBSCRIPTION TO RESERVE
' ============================================================

== Flow 4: Transfer Subscription to Reserve ==

actor "BenefitModule\nor Backend" as caller
caller -> sub ++ : transfer subscription to reserve\n(member wallet)

  alt caller is BenefitModule
    sub -> sub : revenue type = Contribution
  else caller is BACKEND_ADMIN
    sub -> sub : revenue type = ContributionDonation
  end

  sub -> rr ++ : reward parents (child wallet)
  deactivate rr

  group Revenue deposit
    alt member had discount
      sub -> usdc : pull discount amount\nfrom fee claimer
    end
    sub -> rev : deposit revenue\n(amount after fee, revenue type)
  end

sub --> caller : amount transferred
deactivate sub

' ============================================================
' FLOW 5: REFUND
' ============================================================

== Flow 5: Refund ==

backend -> sub ++ : refund member

  sub -> sub : validate refund conditions

  alt used coupon
    sub -> usdc : return funds to coupon pool
  else no coupon
    sub -> usdc : return funds to user wallet
  end

  sub -> ms : mark member as refunded\n(reset all fields)
sub --> backend : refund complete
deactivate sub

' ============================================================
' FLOW 6: PLAN MANAGEMENT (Operator)
' ============================================================

== Flow 6: Plan Management ==

operator -> sub : add association plan (price)
operator -> sub : remove association plan (price)
operator -> sub : disable association plan (price)

@enduml
